---
// No JavaScript in this component. GSAP scroll trigger is added in Sprint 06.
---

<section class="hero">
  <div class="hero-content">
    <h1>Four Centuries of Looking Up</h1>
    <p>
      In 1608, Dutch spectacle maker Hans Lipperhey revealed an instrument that
      made distant objects appear close — the first scientific device to extend
      a human sense and begin four centuries of discovery.
    </p>
  </div>

  <div class="grain-image">
    <img src="/images/blackhole.jpg" alt="A black hole captured by the Event Horizon Telescope" />
  </div>

  <!-- Sprint 06 attaches the GSAP ScrollTrigger to this element -->
  <div id="transition-trigger"></div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 2rem 4rem;
    overflow: hidden;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 48rem;
  }

  h1 {
    font-family: var(--font-primary);
    color: var(--text-color);
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 600;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    transition: color 0.3s ease;
  }

  p {
    font-family: var(--font-primary);
    color: var(--text-color);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    line-height: 1.7;
    max-width: 36rem;
    transition: color 0.3s ease;
  }

  /* Hero image with CSS variable filter */
  .grain-image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .grain-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: var(--img-filter);
    transition: filter 0.8s ease;
  }

  /* Grain overlay using SVG feTurbulence — no external PNG needed */
  .grain-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 200px 200px;
    opacity: 0.18;
    pointer-events: none;
    mix-blend-mode: multiply;
  }

  /* Dark text overlay so headline stays readable over the image */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to right,
      rgba(241, 231, 208, 0.85) 0%,
      rgba(241, 231, 208, 0.4) 60%,
      transparent 100%
    );
    pointer-events: none;
    transition: opacity 0.8s ease;
  }

  :global(body.is-space-era) .hero::before {
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.75) 0%,
      rgba(0, 0, 0, 0.3) 60%,
      transparent 100%
    );
  }

  /* transition-trigger sits at the visual bottom of the hero */
  #transition-trigger {
    position: absolute;
    bottom: 0;
    width: 100%;
    height: 0;
  }
</style>
